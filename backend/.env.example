# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=authbadge_cm14
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_64_bytes_minimum
JWT_REFRESH_SECRET=change_me_refresh_secret_64_bytes_minimum
JWT_ACCESS_EXPIRES=60m
JWT_REFRESH_EXPIRES=7d

# ─── Upload ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=2

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Augmenter pour les tests de charge (ex: 30000). Défaut : 300 req/min global.
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=10

# ─── PostgreSQL pool ──────────────────────────────────────────────────────────
# Nombre max de connexions simultanées. Défaut : 50.
POSTGRES_POOL_MAX=50
