# ── Dépendances ──────────────────────────────────────────────
node_modules/

# ── Build Vite ───────────────────────────────────────────────
dist/
dist-ssr/
dev-dist/

# ── Variables d'environnement (ne jamais versionner) ─────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env.production

# ── Capacitor ────────────────────────────────────────────────
ios/
# android/ inclus — contient des modifications manuelles (AndroidManifest, permissions)
android/.gradle/
android/app/build/
android/build/
android/.idea/
android/local.properties
android/app/.cxx/

# Variables d'environnement Android (IP locale spécifique à la machine)
.env.android

# ── Certificats TLS (ne jamais versionner — clé privée) ──────
backend/certs/key.pem
backend/certs/cert.pem

# ── Signing Android (ne jamais versionner) ────────────────────
android/app/*.jks
android/app/*.keystore
android/app/keystore.properties

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Cache ────────────────────────────────────────────────────
.vite/
.cache/
*.tsbuildinfo

# ── Éditeurs ─────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Système d'exploitation ───────────────────────────────────
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ── Tests ────────────────────────────────────────────────────
coverage/
