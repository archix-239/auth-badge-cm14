# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://authbadge-cm14.cm

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=authbadge_cm14
POSTGRES_USER=authbadge
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_BYTES_RANDOM_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_BYTES_RANDOM_HEX
JWT_ACCESS_EXPIRES=60m
JWT_REFRESH_EXPIRES=7d

# ─── Upload ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=2
